        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "data = pm.response.json();",
                  "req = JSON.parse(pm.request.body.raw)",
                  "",
                  "const tokenKey = 'access';",
                  "const refreshKey = 'refresh';",
                  "",
                  "// Store jwt access_token",
                  "if (typeof data[tokenKey] === \"string\" && data[tokenKey].trim().length > 0) {",
                  "    pm.collectionVariables.set(\"JWT_TOKEN\", data[tokenKey]);",
                  "    pm.environment.set('WORDLE-JWT-1', data[tokenKey])",
                  "}",
                  "",
                  "// Store refresh_token",
                  "if (typeof data[refreshKey] === 'string' && data[refreshKey].trim().length > 0){",
                  "    pm.collectionVariables.set(\"JWT_REFRESH_TOKEN\", data[refreshKey])",
                  "}",
                  "",
                  "// Store username (from request)",
                  "if (typeof req.username === 'string' && req.username.trim().length > 0){",
                  "    pm.collectionVariables.set(\"USERNAME\", req.username);",
                  "}",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"Josh\",\n    \"password\": \"Test123\"\n}",
